{{log "📝 Rendering post" document.id}}
<html lang='{{document.meta.lang}}'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>{{document.meta.title}}</title>
		<link rel='stylesheet' href='{{url (href "/styles/base.css")}}' />
		<link rel='stylesheet' href='{{url (href "/styles/post.css")}}' />
	</head>
	<body>
		<nav>
			<span class='brand'>mikser</span>
			<a class='back' href='{{url (href "/blog")}}'>← Back to Blog</a>
		</nav>

		<div class='post-header'>
			<h1>{{document.meta.title}}</h1>
			<div class='post-meta'>
				{{#if document.meta.date}}
					<span>{{date document.meta.date 'MMMM D, YYYY'}}</span>
				{{/if}}
				{{#if document.meta.tags}}
					<div class='tags'>
						{{#each document.meta.tags}}<span class='tag'>{{this}}</span>{{/each}}
					</div>
				{{/if}}
			</div>
		</div>

		<article>
			{{{markdown document.content}}}
		</article>

		<div class='post-footer'>
			<a href='{{url (href "/blog")}}'>← All posts</a>
			<span>Published with Mikser</span>
		</div>

		<footer>Built with Mikser</footer>
	</body>
</html>
