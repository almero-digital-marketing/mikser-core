<html lang='{{document.meta.lang}}'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>{{document.meta.title}}</title>
		<link rel='stylesheet' href='{{url (href "/styles/base.css")}}' />
		<link rel='stylesheet' href='{{url (href "/styles/index.css")}}' />
	</head>
	<body>
		<nav>
			<span class='brand'>mikser</span>
			<ul>
				<li><a href='{{url (href "/blog/getting-started")}}'>Blog</a></li>
				<li><a href='{{url (href "/en/report.pdf")}}'>Report</a></li>
				{{#each (hrefLang document.meta.href)}}
					{{#unless (eq @key ../document.meta.lang)}}
						<li><a href='{{url (href ../document.meta.href @key)}}'>{{uppercase @key}}</a></li>
					{{/unless}}
				{{/each}}
			</ul>
		</nav>

		<div class='hero'>
			<h1>{{document.meta.title}}</h1>
			<p>{{document.meta.description}}</p>
			<a href='{{url (href "/blog/getting-started")}}'>Read the Blog →</a>
		</div>

		<div>
			<div class='section-title'>Latest Posts</div>
			<div class='posts'>
				{{#with (href '/blog/getting-started')}}
					<div class='post-card'>
						<div class='date'>{{date meta.date 'MMMM D, YYYY'}}</div>
						<h3><a href='{{url}}'>{{meta.title}}</a></h3>
						<p>{{meta.description}}</p>
						<div class='tags'>{{#each meta.tags}}<span class='tag'>{{this}}</span>{{/each}}</div>
					</div>
				{{/with}}
				{{#with (href '/blog/clean-code')}}
					<div class='post-card'>
						<div class='date'>{{date meta.date 'MMMM D, YYYY'}}</div>
						<h3><a href='{{url}}'>{{meta.title}}</a></h3>
						<p>{{meta.description}}</p>
						<div class='tags'>{{#each meta.tags}}<span class='tag'>{{this}}</span>{{/each}}</div>
					</div>
				{{/with}}
				{{#with (href '/blog/handlebars-layouts')}}
					<div class='post-card'>
						<div class='date'>{{date meta.date 'MMMM D, YYYY'}}</div>
						<h3><a href='{{url}}'>{{meta.title}}</a></h3>
						<p>{{meta.description}}</p>
						<div class='tags'>{{#each meta.tags}}<span class='tag'>{{this}}</span>{{/each}}</div>
					</div>
				{{/with}}
			</div>

			{{#if document.meta.image}}
				<div class='section-title'>Media</div>
				<div class='media-grid'>
					<div class='media-card'>
						<img src='{{url (resource document.meta.image)}}' alt='Placeholder image' />
						<div class='caption'>Original via resource plugin</div>
					</div>
					<div class='media-card'>
						<img src='{{url (asset "small-image" (get "name" (resource document.meta.image)) "webp")}}' alt='Processed image' />
						<div class='caption'>WebP via asset preset <code>small-image</code></div>
					</div>
					{{#if document.meta.video}}
						<div class='media-card'>
							<video controls>
								<source src='{{url (resource document.meta.video)}}' type='video/mp4' />
							</video>
							<div class='caption'>Original via resource plugin</div>
						</div>
						<div class='media-card'>
							<video controls>
								<source src='{{url (asset "small-video" (get "name" (resource document.meta.video)) "mp4")}}' type='video/mp4' />
							</video>
							<div class='caption'>MP4 via asset preset <code>small-video</code></div>
						</div>
					{{/if}}
				</div>
			{{/if}}

			<div class='report-cta'>
				<div>
					<h3>Quarterly Report</h3>
					<p>Auto-generated PDF via the <code>post-pdf</code> postprocessor.</p>
				</div>
				<a href='{{url (href "/en/report.pdf")}}' download>Download PDF →</a>
			</div>
		</div>

		<footer>Built with Mikser</footer>
	</body>
</html>
