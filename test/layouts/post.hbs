<html lang='{{document.meta.lang}}'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>{{document.meta.title}}</title>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: system-ui, -apple-system, sans-serif;
				font-size: 1rem;
				line-height: 1.7;
				color: #111;
				background: #fff;
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1.5rem;
			}
			a { color: inherit; }
			a:hover { text-decoration: none; }

			/* Nav */
			nav {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				border-bottom: 1px solid #111;
				padding-bottom: .75rem;
				margin-bottom: 3rem;
			}
			nav .brand { font-weight: 700; font-size: 1rem; }
			nav .back { font-size: .9rem; text-decoration: underline; }

			/* Header */
			.post-header { margin-bottom: 2rem; }
			.post-header h1 { font-size: 1.75rem; font-weight: 700; line-height: 1.25; margin-bottom: .6rem; }
			.post-meta { display: flex; flex-wrap: wrap; gap: .4rem 1rem; font-size: .8rem; color: #888; }
			.tags { display: flex; flex-wrap: wrap; gap: .3rem; }
			.tag { font-size: .7rem; border: 1px solid #ccc; padding: .1rem .4rem; color: #555; }

			/* Article */
			article { border-top: 1px solid #ddd; padding-top: 1.5rem; }
			article h1, article h2, article h3 { margin: 1.75rem 0 .6rem; line-height: 1.3; }
			article h1 { font-size: 1.5rem; }
			article h2 { font-size: 1.2rem; border-bottom: 1px solid #eee; padding-bottom: .3rem; }
			article h3 { font-size: 1rem; }
			article p { margin-bottom: 1.1rem; }
			article ul, article ol { padding-left: 1.6rem; margin-bottom: 1.1rem; }
			article li { margin-bottom: .3rem; }
			article code {
				font-family: 'Fira Code', 'Courier New', monospace;
				font-size: .85em;
				background: #f5f5f5;
				padding: .1em .35em;
				border-radius: 2px;
			}
			article pre {
				background: #f5f5f5;
				border: 1px solid #ddd;
				border-radius: 3px;
				padding: 1rem 1.25rem;
				overflow-x: auto;
				margin-bottom: 1.2rem;
			}
			article pre code { background: none; padding: 0; font-size: .85rem; }
			article blockquote {
				border-left: 3px solid #ccc;
				margin: 1.25rem 0;
				padding: .6rem 1rem;
				color: #555;
				font-style: italic;
			}

			/* Footer */
			.post-footer {
				margin-top: 2.5rem;
				padding-top: .75rem;
				border-top: 1px solid #ddd;
				display: flex;
				justify-content: space-between;
				font-size: .8rem;
				color: #888;
			}
			.post-footer a { text-decoration: underline; }

			footer {
				border-top: 1px solid #111;
				padding-top: .75rem;
				margin-top: 3rem;
				font-size: .8rem;
				color: #888;
			}
		</style>
	</head>
	<body>
		<nav>
			<span class='brand'>Mikser</span>
			<a class='back' href='{{url (href "/blog")}}'>← Back to Blog</a>
		</nav>

		<div class='post-header'>
			<h1>{{document.meta.title}}</h1>
			<div class='post-meta'>
				{{#if document.meta.date}}
					<span>{{date document.meta.date 'MMMM D, YYYY'}}</span>
				{{/if}}
				{{#if document.meta.tags}}
					<div class='tags'>
						{{#each document.meta.tags}}<span class='tag'>{{this}}</span>{{/each}}
					</div>
				{{/if}}
			</div>
		</div>

		<article>
			{{{markdown document.content}}}
		</article>

		<div class='post-footer'>
			<a href='{{url (href "/blog")}}'>← All posts</a>
			<span>Published with Mikser</span>
		</div>

		<footer>Built with Mikser</footer>
	</body>
</html>
