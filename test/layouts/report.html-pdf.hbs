<!DOCTYPE html>
<html lang='{{document.meta.lang}}'>
<head>
	<meta charset='UTF-8' />
	<title>{{document.meta.title}}</title>
	<style>
		*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
		body {
			font-family: Georgia, 'Times New Roman', serif;
			font-size: .95rem;
			line-height: 1.75;
			color: #111;
			background: #fff;
			padding: 60px 72px;
			max-width: 860px;
			margin: 0 auto;
		}
		a { color: inherit; }

		/* Cover */
		.cover {
			border-bottom: 2px solid #111;
			padding-bottom: 1.75rem;
			margin-bottom: 2.5rem;
		}
		.cover .label {
			font-family: system-ui, sans-serif;
			font-size: .7rem;
			text-transform: uppercase;
			letter-spacing: .15em;
			font-weight: 700;
			margin-bottom: .5rem;
		}
		.cover h1 { font-size: 2rem; font-weight: 700; line-height: 1.2; margin-bottom: .75rem; }
		.cover .meta {
			font-family: system-ui, sans-serif;
			font-size: .8rem;
			color: #666;
			display: flex;
			gap: 2rem;
		}

		/* Body */
		h2 { font-size: 1.2rem; font-weight: 700; margin: 2.25rem 0 .6rem; border-bottom: 1px solid #ddd; padding-bottom: .3rem; }
		h3 { font-size: 1rem; font-weight: 700; margin: 1.5rem 0 .5rem; }
		p { margin-bottom: 1rem; }
		ul, ol { padding-left: 1.6rem; margin-bottom: 1rem; }
		li { margin-bottom: .3rem; }
		strong { font-weight: 700; }
		em { font-style: italic; }

		/* Code */
		code {
			font-family: 'Courier New', monospace;
			font-size: .82em;
			background: #f5f5f5;
			padding: .1em .3em;
			border-radius: 2px;
		}
		pre {
			background: #f5f5f5;
			border: 1px solid #ddd;
			border-radius: 3px;
			padding: 1rem 1.25rem;
			overflow-x: auto;
			margin-bottom: 1.2rem;
			font-size: .82rem;
			line-height: 1.6;
		}
		pre code { background: none; padding: 0; }

		/* Table */
		table {
			width: 100%;
			border-collapse: collapse;
			font-family: system-ui, sans-serif;
			font-size: .875rem;
			margin-bottom: 1.5rem;
		}
		th {
			border-bottom: 2px solid #111;
			text-align: left;
			padding: .5rem .75rem;
			font-weight: 700;
		}
		td {
			padding: .45rem .75rem;
			border-bottom: 1px solid #e8e8e8;
		}
		tr:nth-child(even) td { background: #fafafa; }

		/* Blockquote */
		blockquote {
			border-left: 3px solid #ccc;
			margin: 1.25rem 0;
			padding: .6rem 1rem;
			color: #555;
			font-style: italic;
		}

		/* Footer */
		.doc-footer {
			margin-top: 3rem;
			padding-top: .75rem;
			border-top: 1px solid #ddd;
			font-family: system-ui, sans-serif;
			font-size: .75rem;
			color: #aaa;
			display: flex;
			justify-content: space-between;
		}

		.page-break { page-break-after: always; }

		@media print {
			body { padding: 0; }
			@page { margin: 2cm 2.5cm; }
		}
	</style>
</head>
<body>
	<div class='cover'>
		<div class='label'>Report</div>
		<h1>{{document.meta.title}}</h1>
		<div class='meta'>
			{{#if document.meta.date}}<span>{{document.meta.date}}</span>{{/if}}
			{{#if document.meta.author}}<span>{{document.meta.author}}</span>{{/if}}
			{{#if document.meta.version}}<span>v{{document.meta.version}}</span>{{/if}}
		</div>
	</div>

	{{{markdown document.content}}}

	<div class='doc-footer'>
		<span>Generated by Mikser</span>
		<span>{{document.meta.title}}</span>
	</div>
</body>
</html>
