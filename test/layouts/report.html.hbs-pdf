<!DOCTYPE html>
<html lang="{{document.meta.lang}}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{document.meta.title}}</title>
    <style>
        body {
            font-family: Georgia, serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 0 40px;
            color: #222;
            line-height: 1.7;
        }
        h1 {
            font-size: 2em;
            border-bottom: 2px solid #444;
            padding-bottom: 0.3em;
            margin-bottom: 0.5em;
        }
        .meta {
            color: #666;
            font-size: 0.9em;
            margin-bottom: 2em;
        }
        .meta span {
            margin-right: 1.5em;
        }
    </style>
</head>
<body>
    <h1>{{document.meta.title}}</h1>
    <div class="meta">
        <span>Date: {{document.meta.date}}</span>
        {{#if document.meta.author}}<span>Author: {{document.meta.author}}</span>{{/if}}
    </div>
    {{{markdown document.content}}}
</body>
</html>
